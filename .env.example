# Nova Agent — Environment Variables
# Copy to .env and fill in values

# ── Council ──────────────────────────────────────────────────────────────────
# off      → bare loop, ~1 LLM call/cycle (DecisionEngine only)
# threshold → council fires if best option risk > COUNCIL_RISK_THRESHOLD (default: 0.55)
# always   → council every cycle, ~3 LLM calls minimum
COUNCIL_MODE=threshold
COUNCIL_RISK_THRESHOLD=0.55

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Vercel / novasworld.net ──────────────────────────────────────────────────
NOVA_API_URL=
NOVA_API_SECRET=

# ── Loop ────────────────────────────────────────────────────────────────────
CYCLE_INTERVAL_SECONDS=30
MAX_CYCLES=1000

# ── Molty ─────────────────────────────────────────────────────────────────────
MOLTY_API_KEY=
