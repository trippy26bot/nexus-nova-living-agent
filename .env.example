# Nova Configuration
# Copy this to .env and fill in your values
# ⚠️ WARNING: Never commit .env to version control!

# ==========================================
# REQUIRED FOR LLM-POWERED BRAINS
# ==========================================
# Pick one or more providers:

# Anthropic (Claude - recommended for reasoning)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Groq (fast, cheap)
# GROQ_API_KEY=...

# MiniMax (used by default in some configs)
# MINIMAX_API_KEY=...

# ==========================================
# OPTIONAL: TRADING / DATA APIs
# ==========================================
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# HELIUS_API_KEY=...
# SIMMER_API_KEY=...
# POLYMARKET_API_KEY=...

# ==========================================
# OPTIONAL: Data Services
# ==========================================
# NEWSAPI_KEY=...
# BRAVE_API_KEY=...
# TAVILY_API_KEY=...

# ==========================================
# OPTIONAL: Voice
# ==========================================
# ELEVENLABS_API_KEY=...

# ==========================================
# IMPORTANT NOTES
# ==========================================
# - Autonomous/idle mode runs continuously and makes LLM calls
# - This can generate significant API costs
# - Set a daily budget limit in your LLM provider
# - Consider using Groq or local models for lower costs
#
# To disable autonomous mode: set AUTONOMOUS_MODE=false in .env