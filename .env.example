# Nova Configuration
# Copy this to .env and fill in your values
# ⚠️ WARNING: Never commit .env to version control!

# ==========================================
# LLM API KEYS (your choice of provider)
# ==========================================
# Add keys for whichever LLM provider(s) you want to use
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=...
# MINIMAX_API_KEY=...

# ==========================================
# OPTIONAL: TRADING / DATA APIs
# ==========================================
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# HELIUS_API_KEY=...
# SIMMER_API_KEY=...
# POLYMARKET_API_KEY=...

# ==========================================
# OPTIONAL: Data Services
# ==========================================
# NEWSAPI_KEY=...
# BRAVE_API_KEY=...
# TAVILY_API_KEY=...

# ==========================================
# OPTIONAL: Voice
# ==========================================
# ELEVENLABS_API_KEY=...

# ==========================================
# IMPORTANT NOTES
# ==========================================
# - Autonomous/idle mode runs continuously and makes LLM calls
# - This can generate significant API costs depending on provider
# - Set a daily budget limit in your LLM provider
# - Local models can be used to reduce costs
#
# To disable autonomous mode: set AUTONOMOUS_MODE=false in .env